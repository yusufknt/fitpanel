// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  COACH
  STUDENT
}

enum LeadStatus {
  NEW
  QUALIFIED
  CONVERTED
  LOST
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  coachProfile CoachProfile?
  student      StudentProfile?
  notifications Notification[]
}

model CoachProfile {
  id         String           @id @default(cuid())
  userId     String           @unique
  slug       String           @unique
  fullName   String
  bio        String?
  specialty  String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  students   StudentProfile[]
  packages   CoachingPackage[]
  leads      ApplicationLead[]
}

model StudentProfile {
  id            String          @id @default(cuid())
  userId         String          @unique
  coachId        String
  startDate      DateTime        @default(now())
  fullName      String?
  phone         String?
  heightCm      Float?
  goal           String?
  notes          String?
  coachProgram   String?
  programUpdatedAt DateTime?
  targetProteinG   Float?
  targetCarbG      Float?
  targetFatG       Float?
  targetCalories   Int?
  dietPlanText     String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  coach          CoachProfile    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  checkIns       CheckIn[]
  metrics        BodyMetric[]
  progressPhotos ProgressPhoto[]
  dailyLogs      StudentDailyLog[]
  workoutEntries StudentWorkoutEntry[]
  reports        WeeklyReport[]
}

model CheckIn {
  id              String         @id @default(cuid())
  studentId       String
  weekStart       DateTime
  mood            String?
  complianceScore Int?
  notes           String?
  coachFeedback   String?
  submittedAt     DateTime       @default(now())
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, weekStart])
}

model BodyMetric {
  id        String         @id @default(cuid())
  studentId String
  date      DateTime
  weight    Float?
  waist     Float?
  chest     Float?
  arm       Float?
  leg       Float?
  bodyFat   Float?
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, date])
}

model ProgressPhoto {
  id         String         @id @default(cuid())
  studentId  String
  date       DateTime
  photoType  String
  fileUrl    String
  visibility String         @default("coach_student")
  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, date])
}

model StudentDailyLog {
  id              String         @id @default(cuid())
  studentId       String
  dayKey          String
  waterGlasses    Int            @default(0)
  breakfastDone   Boolean        @default(false)
  lunchDone       Boolean        @default(false)
  dinnerDone      Boolean        @default(false)
  snackDone       Boolean        @default(false)
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, dayKey])
}

model StudentWorkoutEntry {
  id             String         @id @default(cuid())
  studentId      String
  performedAt    DateTime       @default(now())
  exerciseName   String
  setIndex       Int
  targetReps     Int?
  actualReps     Int?
  targetWeightKg Float?
  actualWeightKg Float?
  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, performedAt])
}

model CoachingPackage {
  id            String       @id @default(cuid())
  coachId       String
  title         String
  durationWeeks Int
  price         Float
  description   String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  coach         CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
}

model ApplicationLead {
  id        String       @id @default(cuid())
  coachId   String
  fullName  String
  email     String
  phone     String?
  goal      String?
  source    String?
  status    LeadStatus   @default(NEW)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  coach     CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  channel   String
  template  String
  status    String   @default("queued")
  sentAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model WeeklyReport {
  id        String         @id @default(cuid())
  studentId String
  title     String
  fileUrl   String
  createdAt DateTime       @default(now())
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}
